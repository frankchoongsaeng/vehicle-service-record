# Database

MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_DATABASE="duralog"
MYSQL_USER="duralog"
MYSQL_PASSWORD="duralog"
MYSQL_ROOT_PASSWORD="root"

# Auth

OPENAUTH_SECRET="replace-this-secret-for-production"
OPENAUTH_ISSUER="vehicle-service-record-openauth"
OPENAUTH_AUDIENCE="vehicle-service-record-client"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# App links and user-facing email flows
# APP_ORIGIN is the canonical frontend origin used for CORS enforcement,
# generated app URLs, and hosted branding assets in emails.

APP_ORIGIN=""
APP_BILLING_RETURN_URL=""
EMAIL_VERIFICATION_TTL_HOURS="24"
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS="60"
PASSWORD_RESET_TTL_HOURS="2"
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS="60"

# Development seed user

DEV_USER_EMAIL="demo.user@example.com"
DEV_USER_PASSWORD="change-me123"
SEED_ON_STARTUP="false"

# Logging

LOG_LEVEL="debug"
LOG_READ_REQUEST_SAMPLE_RATE="1"
LOG_FILE_PATH="./logs/backend.ndjson"

# Bugsink monitoring
# Bugsink accepts standard Sentry SDK DSNs. Set BUGSINK_DSN for the server and
# VITE_BUGSINK_DSN for the browser if you want frontend events as well.

BUGSINK_ENABLED="true"
BUGSINK_DSN=""
BUGSINK_ENVIRONMENT="development"
BUGSINK_TRACES_SAMPLE_RATE="0.15"
BUGSINK_PROFILES_SAMPLE_RATE="0"

VITE_BUGSINK_ENABLED="true"
VITE_BUGSINK_DSN=""
VITE_BUGSINK_ENVIRONMENT="development"
VITE_BUGSINK_TRACES_SAMPLE_RATE="0.15"
VITE_BUGSINK_REPLAYS_SESSION_SAMPLE_RATE="0"
VITE_BUGSINK_REPLAYS_ON_ERROR_SAMPLE_RATE="1"

# Reminder scheduler and alert delivery
# Run the reminder scheduler only in the dedicated worker process.
# Web processes should override REMINDER_SCHEDULER_ENABLED=false.

REMINDER_SCHEDULER_ENABLED="true"
REMINDER_RUN_ON_STARTUP="true"
REMINDER_EVALUATION_HOUR_UTC="8"
REMINDER_RETRY_INTERVAL_MINUTES="15"
REMINDER_RETRY_BACKOFF_MINUTES="15"
REMINDER_MAX_RETRIES="3"

# SMTP transport

SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# SMTP sender addresses
# SMTP_FROM remains a backward-compatible fallback if a category-specific sender is unset.
SMTP_FROM=""
SMTP_FROM_ALERTS=""
SMTP_FROM_SECURITY=""
SMTP_FROM_WELCOME=""

# Stripe billing

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_PLUS_MONTHLY=""
STRIPE_PRICE_ID_PLUS_YEARLY=""
STRIPE_PRICE_ID_GARAGE_MONTHLY=""
STRIPE_PRICE_ID_GARAGE_YEARLY=""

# OpenAI image services

OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_IMAGE_CLASSIFIER_MODEL="gpt-4.1-mini"

# Bunny storage

BUNNY_STORAGE_ZONE_NAME=""
BUNNY_STORAGE_ACCESS_KEY=""
BUNNY_STORAGE_REGION="Falkenstein"
BUNNY_PUBLIC_BASE_URL=""