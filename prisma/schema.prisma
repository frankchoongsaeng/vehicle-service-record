generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = "file:./prisma/dev.db"
}

model User {
    id            String   @id @default(cuid())
    email         String   @unique
    password_hash String
    created_at    DateTime @default(now())
    updated_at    DateTime @updatedAt

    vehicles          Vehicle[]
    service_records   ServiceRecord[]
    maintenance_plans MaintenancePlan[]

    @@map("users")
}

model Vehicle {
    id               Int      @id @default(autoincrement())
    user_id          String
    image_id         Int?
    make             String
    model            String
    year             Int
    trim             String
    vehicle_type     String?
    plate_number     String?
    vin              String?
    engine           String?
    transmission     String
    fuel_type        String
    purchase_mileage Int?
    mileage          Int?
    color            String?
    notes            String?
    created_at       DateTime @default(now())
    updated_at       DateTime @updatedAt

    user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
    image             VehicleImage?     @relation(fields: [image_id], references: [id], onDelete: SetNull)
    service_records   ServiceRecord[]
    maintenance_plans MaintenancePlan[]

    @@index([user_id])
    @@index([image_id])
    @@map("vehicles")
}

model VehicleImage {
    id                 Int       @id @default(autoincrement())
    classification_key String    @unique
    make               String
    model              String
    color              String
    year_start         Int
    year_end           Int
    trim               String?
    vehicle_type       String?
    body_style         String?
    view               String    @default("default")
    generation_key     String?
    prompt_version     String?
    image_storage_key  String    @unique
    local_tmp_filename String?
    classifier_status  String    @default("pending")
    classifier_error   String?
    classified_at      DateTime?
    generation_status  String    @default("pending")
    generation_error   String?
    upload_status      String    @default("pending")
    upload_error       String?
    uploaded_at        DateTime?
    created_at         DateTime  @default(now())
    updated_at         DateTime  @updatedAt

    vehicles Vehicle[]

    @@index([make, model, color])
    @@index([year_start, year_end])
    @@map("vehicle_images")
}

model ServiceRecord {
    id                       Int      @id @default(autoincrement())
    user_id                  String
    vehicle_id               Int
    maintenance_plan_id      Int?
    maintenance_plan_item_id Int?
    service_type             String
    description              String
    date                     String
    mileage                  Int?
    cost                     Float?
    notes                    String?
    created_at               DateTime @default(now())
    updated_at               DateTime @updatedAt

    user                  User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
    vehicle               Vehicle              @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
    maintenance_plan      MaintenancePlan?     @relation("MaintenancePlanRecords", fields: [maintenance_plan_id], references: [id], onDelete: SetNull)
    maintenance_plan_item MaintenancePlanItem? @relation("MaintenancePlanItemRecords", fields: [maintenance_plan_item_id], references: [id], onDelete: SetNull)

    @@index([user_id])
    @@index([vehicle_id])
    @@index([maintenance_plan_id])
    @@index([maintenance_plan_item_id])
    @@index([user_id, vehicle_id])
    @@map("service_records")
}

model MaintenancePlan {
    id                     Int      @id @default(autoincrement())
    user_id                String
    vehicle_id             Int
    title                  String
    description            String?
    interval_months        Int?
    interval_mileage       Int?
    last_completed_date    String?
    last_completed_mileage Int?
    created_at             DateTime @default(now())
    updated_at             DateTime @updatedAt

    user            User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
    vehicle         Vehicle               @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
    items           MaintenancePlanItem[]
    service_records ServiceRecord[]       @relation("MaintenancePlanRecords")

    @@index([user_id])
    @@index([vehicle_id])
    @@index([user_id, vehicle_id])
    @@map("maintenance_plans")
}

model MaintenancePlanItem {
    id                  Int      @id @default(autoincrement())
    maintenance_plan_id Int
    name                String
    created_at          DateTime @default(now())
    updated_at          DateTime @updatedAt

    maintenance_plan MaintenancePlan @relation(fields: [maintenance_plan_id], references: [id], onDelete: Cascade)
    service_records  ServiceRecord[] @relation("MaintenancePlanItemRecords")

    @@index([maintenance_plan_id])
    @@map("maintenance_plan_items")
}
