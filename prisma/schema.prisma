generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

model User {
    id                      String   @id @default(cuid())
    email                   String   @unique
    password_hash           String?
    google_subject          String?  @unique
    stripe_customer_id      String?  @unique
    plan_code               String   @default("free")
    billing_interval        String?
    subscription_status     String   @default("free")
    current_period_end      DateTime?
    cancel_at_period_end    Boolean  @default(false)
    provider_subscription_id String? @unique
    provider_price_id       String?
    email_verified_at       DateTime?
    email_verification_token_hash String?  @unique
    email_verification_expires_at DateTime?
    email_verification_sent_at    DateTime?
    password_reset_token_hash     String?  @unique
    password_reset_expires_at     DateTime?
    password_reset_sent_at        DateTime?
    first_name              String?
    last_name               String?
    country                 String?
    profile_image_url       String?
    preferred_currency      String   @default("USD")
    history_sort_order      String   @default("newest_first")
    reminder_email_enabled  Boolean  @default(true)
    reminder_digest_enabled Boolean  @default(true)
    onboarding_completed_at DateTime?
    created_at              DateTime @default(now())
    updated_at              DateTime @updatedAt

    vehicles          Vehicle[]
    service_records   ServiceRecord[]
    maintenance_plans MaintenancePlan[]
    workshops         Workshop[]
    reminder_rules    ReminderRule[]
    notifications     Notification[]

    @@map("users")
}

model Vehicle {
    id               Int      @id @default(autoincrement())
    user_id          String
    image_id         Int?
    make             String
    model            String
    year             Int
    trim             String
    vehicle_type     String?
    plate_number     String?
    vin              String?
    engine           String?
    transmission     String
    fuel_type        String
    purchase_mileage Int?
    mileage          Int?
    distance_unit    String   @default("mi")
    reminder_mode    String   @default("inherit")
    color            String?
    notes            String?
    created_at       DateTime @default(now())
    updated_at       DateTime @updatedAt

    user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
    image             VehicleImage?     @relation(fields: [image_id], references: [id], onDelete: SetNull)
    service_records   ServiceRecord[]
    maintenance_plans MaintenancePlan[]
    reminder_rules    ReminderRule[]

    @@index([user_id])
    @@index([image_id])
    @@map("vehicles")
}

model VehicleImage {
    id                 Int       @id @default(autoincrement())
    classification_key String    @unique
    make               String
    model              String
    color              String
    year_start         Int
    year_end           Int
    trim               String?
    vehicle_type       String?
    body_style         String?
    view               String    @default("default")
    generation_key     String?
    prompt_version     String?
    image_storage_key  String    @unique
    local_tmp_filename String?
    classifier_status  String    @default("pending")
    classifier_error   String?
    classified_at      DateTime?
    generation_status  String    @default("pending")
    generation_error   String?
    upload_status      String    @default("pending")
    upload_error       String?
    uploaded_at        DateTime?
    created_at         DateTime  @default(now())
    updated_at         DateTime  @updatedAt

    vehicles Vehicle[]

    @@index([make, model, color])
    @@index([year_start, year_end])
    @@map("vehicle_images")
}

model ServiceRecord {
    id                  Int      @id @default(autoincrement())
    user_id             String
    vehicle_id          Int
    maintenance_plan_id Int?
    service_type        String
    workshop            String?
    description         String
    date                String
    mileage             Int?
    cost                Float?
    notes               String?
    created_at          DateTime @default(now())
    updated_at          DateTime @updatedAt

    user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
    vehicle          Vehicle          @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
    maintenance_plan MaintenancePlan? @relation("MaintenancePlanRecords", fields: [maintenance_plan_id], references: [id], onDelete: SetNull)

    @@index([user_id])
    @@index([vehicle_id])
    @@index([maintenance_plan_id])
    @@index([user_id, vehicle_id])
    @@map("service_records")
}

model MaintenancePlan {
    id                     Int      @id @default(autoincrement())
    user_id                String
    vehicle_id             Int
    service_type           String   @default("other")
    title                  String
    description            String?
    interval_months        Int?
    interval_mileage       Int?
    last_completed_date    String?
    last_completed_mileage Int?
    created_at             DateTime @default(now())
    updated_at             DateTime @updatedAt

    user            User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
    vehicle         Vehicle         @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
    service_records ServiceRecord[] @relation("MaintenancePlanRecords")

    @@index([user_id])
    @@index([vehicle_id])
    @@index([user_id, vehicle_id])
    @@map("maintenance_plans")
}

model Workshop {
    id         Int      @id @default(autoincrement())
    user_id    String
    name       String
    address    String?
    phone      String?
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
    @@index([user_id, name])
    @@map("workshops")
}

model ReminderRule {
    id                Int      @id @default(autoincrement())
    user_id           String
    vehicle_id        Int?
    channel           String   @default("email")
    days_threshold    Int?
    mileage_threshold Int?
    created_at        DateTime @default(now())
    updated_at        DateTime @updatedAt

    user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
    vehicle Vehicle? @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

    @@index([user_id])
    @@index([vehicle_id])
    @@index([user_id, vehicle_id, channel])
    @@map("reminder_rules")
}

model Notification {
    id            Int       @id @default(autoincrement())
    user_id       String
    channel       String    @default("email")
    kind          String    @default("maintenance_digest")
    status        String    @default("pending")
    subject       String
    body_text     String
    body_html     String
    dedupe_key    String    @unique
    item_count    Int       @default(0)
    retry_count   Int       @default(0)
    scheduled_for DateTime
    next_retry_at DateTime?
    sent_at       DateTime?
    last_error    String?
    created_at    DateTime  @default(now())
    updated_at    DateTime  @updatedAt

    user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
    delivery_attempts DeliveryAttempt[]

    @@index([user_id])
    @@index([status, next_retry_at])
    @@index([scheduled_for])
    @@map("notifications")
}

model DeliveryAttempt {
    id              Int       @id @default(autoincrement())
    notification_id Int
    channel         String    @default("email")
    provider        String
    status          String
    attempt_number  Int
    response        String?
    error           String?
    started_at      DateTime  @default(now())
    completed_at    DateTime?
    created_at      DateTime  @default(now())

    notification Notification @relation(fields: [notification_id], references: [id], onDelete: Cascade)

    @@index([notification_id])
    @@index([status])
    @@map("delivery_attempts")
}
